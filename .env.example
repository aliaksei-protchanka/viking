# Credentials for panel.kuchniavikinga.pl
VIKING_EMAIL=
VIKING_PASSWORD=
VIKING_BASE_URL=https://panel.kuchniavikinga.pl

# LLM provider: "github" (default, free for personal use), "openai", or "anthropic"
VIKING_LLM_PROVIDER=github
VIKING_LLM_MODEL=openai/gpt-4o-mini

# Set the credential matching the provider above:
# - github:    PAT with `models:read` scope (https://github.com/settings/tokens)
GITHUB_TOKEN=
# - openai:    https://platform.openai.com/api-keys
OPENAI_API_KEY=
# - anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: directory for plans/history
VIKING_STATE_DIR=~/.viking

# Optional: default prompt file used when --prompt/--prompt-file are omitted.
# Lookup order if unset: $VIKING_STATE_DIR/prompt.md → ./prompts/default.md
VIKING_PROMPT_FILE=
